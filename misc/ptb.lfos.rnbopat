, 							{
								"box" : 								{
									"code" : "@param({min: 0.00001, max: 0.05}) dt = 0.01;\r\n\r\n@state x = 0.1;\r\n@state y = 0.1;\r\n@state z = 0.1;\r\n \r\n@state random = 1;\r\n\r\n/* \r\nchecks if this is the first time the code has been \r\nrun and sets x, y and z to random values\r\n*/\r\nif (random == 1) {\r\n\tx = random(0.1, 1);\r\n\ty = random(0.1, 1);\r\n\tz = random(0.1, 1);\r\n\trandom = random + 1;\r\n\t\r\n};\r\n\r\nx = x + ((10 * (y - x)) * dt);\r\ny = y + (((x * (28 - z)) - y) * dt);\r\nz = z + (((x * y) - (z * 2.67)) * dt);\r\n\r\n/* \r\noutput with some scaling to keep outputs loosely \r\nbetween -1 and 1 and clips any values outside this\r\n*/\r\nout1 = clamp(x * 0.05, -1, 1);\r\nout2 = clamp(y * 0.05, -1, 1);\r\nout3 = clamp(z * 0.02, -1, 1);",
									"fontface" : 0,
									"fontname" : "<Monospaced>",
									"fontsize" : 12.0,
									"id" : "obj-1",
									"maxclass" : "codebox",
